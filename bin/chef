#!/usr/bin/env node

import * as fs from 'node:fs';
import * as path from 'node:path';
import { createRequire } from 'node:module';

const require = createRequire(import.meta.url);

require('tsx').globalPreload();

if (fs.existsSync(path.resolve(import.meta.dirname, '../dist/cli.js')))
{
		require('../dist/cli.js');
}
else
{
		require('../src/cli.ts');
}
