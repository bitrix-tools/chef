{
  "name": "@bitrix/chef",
  "version": "0.0.0-beta.11",
  "description": "Bitrix frontend tool",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/**/*",
    "dist/**/*",
    "dist/**/*",
    "src/**/*",
    "types/**/*",
    "tsconfig.json"
  ],
  "types": "./types/index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "prebuild": "mkdir dist/ && cp -r src/commands/create/templates dist/ && cp -r src/commands/init/templates dist/",
    "build": "tsup-node ./src/cli.ts --format esm --splitting=false",
    "test": "tsx --import=tsx/esm ./node_modules/.bin/mocha ./test/**/*.test.ts --inline-diffs --color=true",
    "test:watch": "tsx watch --import=tsx/esm ./node_modules/.bin/mocha ./test/**/*.test.ts --inline-diffs --color=true",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "bin": {
    "chef": "./bin/chef"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bitrix-tools/chef.git"
  },
  "homepage": "https://github.com/bitrix-tools/chef#readme",
  "bugs": {
    "url": "https://github.com/bitrix-tools/chef/issues"
  },
  "author": "Bitrix",
  "license": "MIT",
  "devDependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@types/babel__core": "^7.20.5",
    "@types/chai": "^5.2.3",
    "@types/eslint": "^9.6.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.12",
    "@types/sinon": "^21.0.0",
    "sinon": "^21.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "@babel/core": "^7.28.3",
    "@babel/plugin-external-helpers": "^7.27.1",
    "@babel/plugin-transform-flow-strip-types": "^7.27.1",
    "@babel/preset-env": "^7.28.3",
    "@inquirer/prompts": "^8.2.0",
    "@playwright/test": "^1.57.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-image": "^3.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@rollup/plugin-url": "^8.0.2",
    "autoprefixer": "^10.4.27",
    "boxen": "^8.0.1",
    "browserslist": "^4.28.1",
    "chai": "^6.2.1",
    "chalk": "^5.6.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.0",
    "concat-with-sourcemaps": "^1.1.0",
    "eslint": "^8.57.1",
    "fast-glob": "^3.3.3",
    "log-symbols": "^7.0.1",
    "mocha": "^11.7.5",
    "ora": "^8.2.0",
    "p-queue": "^8.1.0",
    "php-parser": "^3.2.5",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "postcss-svgo": "^7.1.0",
    "postcss-url": "^10.1.3",
    "prettier": "^3.7.4",
    "prettier-plugin-brace-style": "^0.8.2",
    "rollup": "^4.49.0",
    "rollup-plugin-postcss": "^4.0.2",
    "terser": "^5.43.1",
    "text-table": "^0.2.0",
    "tslib": "^2.8.1",
    "tsx": "^4.20.3"
  },
  "optionalDependencies": {
    "weak": "^1.0.1"
  },
  "directories": {
    "test": "test"
  },
  "keywords": [
    "bitrix",
    "cli",
    "builder",
    "linter",
    "test-runner",
    "orchestrator",
    "chef"
  ]
}
